#!/bin/bash
#
# This was used for the final update in response to:
# https://bugzilla.mozilla.org/show_bug.cgi?id=2012573#c23
#
set -euo pipefail

#git clone https://github.com/thunderbird/infra-testing
#cd infra-testing
#git clone https://github.com/thunderbird/thunderbird-desktop
cd thunderbird-desktop

git remote add comm hg::https://hg.mozilla.org/comm-unified/
git config remote.comm.cinnabar-refs bookmarks
git fetch comm

# Fetch Mercurial tags. A plain "git fetch --tags hg::URL" does NOT surface hg
# tags through git-cinnabar; only "git cinnabar fetch --tags" materializes them
# into refs/tags/. Run after fetching comm so the commits the tags point to exist.
git cinnabar fetch --tags

git branch --all

branches=(main beta release esr153 esr140 esr128 esr115)

for b in "${branches[@]}"; do
  git checkout "$b"

  if [[ "$b" == "main" ]]; then
    git rebase remotes/comm/comm
  else
    git merge --ff-only "remotes/comm/comm-$b"
  fi
done

git remote remove comm

echo
echo "Now run on each branch to verify hg metadata:"
echo "  git log --notes=cinnabar"
echo "  git log --notes=cinnabar a5e1b64 -2"
echo
echo "And then:"
echo "  git push --all --tags"
